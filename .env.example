# Relay
RELAY_ADDRESS=localhost:3334
RELAY_DOMAIN=relay.vertexlab.io
RELAY_QUEUE_CAPACITY=2000
RELAY_PROCESSORS=10
RELAY_LOG_EVERY=1000
RELAY_SECRET_KEY=

# API
API_LOG_EVERY=1000
API_SECRET_KEY=

# Service
REDIS_ADDRESS=localhost:6379
SQLITE_PATH=relay.sqlite

# Credits
CREDITS_REFILL_AMOUNT=100
CREDITS_REFILL_INTERVAL=24h
CREDITS_REFILL_WALK_THRESHOLD=100

# IP Rate Limiting
RATE_TRUSTED_LIST=
RATE_TRUSTED_INITIAL_TOKENS=10000
RATE_TRUSTED_MAX_TOKENS=10000
RATE_TRUSTED_TOKENS_PER_INTERVAL=2000
RATE_TRUSTED_INTERVAL=1m

RATE_UNTRUSTED_LIST=
RATE_UNTRUSTED_INITIAL_TOKENS=0
RATE_UNTRUSTED_MAX_TOKENS=0
RATE_UNTRUSTED_TOKENS_PER_INTERVAL=0
RATE_UNTRUSTED_INTERVAL=0s

RATE_UNKNOWN_INITIAL_TOKENS=300
RATE_UNKNOWN_MAX_TOKENS=300
RATE_UNKNOWN_TOKENS_PER_INTERVAL=100
RATE_UNKNOWN_INTERVAL=1m
